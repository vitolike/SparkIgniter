# ==========================================
# CONFIGURAÇÕES DA APLICAÇÃO (APP)
# ==========================================
# APP_ENV: 'dev' ou 'production' (Define exibição de erros)
APP_ENV=dev
# LOG_CHANNEL: Para onde enviar os logs (Ex: file, syslog, both)
LOG_CHANNEL=both
# CORS: Controle de acesso (use '*' para liberar tudo ou especifique domínios)
CORS=*
# Roteamento padrão quando acessam a raiz do sistema
DEFAULT_CONTROLLER=Home
DEFAULT_METHOD=index
# Versão do motor
BP_PHP_VERSION=8.4.13

# ==========================================
# CONFIGURAÇÕES DE BANCO DE DADOS (DB)
# ==========================================
# DB_DRIVER: 'pgsql' para PostgreSQL ou 'mysql' para MariaDB/MySQL
DB_DRIVER=
DB_HOST=
DB_PORT=
DB_NAME=
DB_USER=
DB_PASS=

# ==========================================
# CONFIGURAÇÕES DE SEGURANÇA (JWT)
# ==========================================
# JWT_SECRET: Chave criptográfica única de validação (NUNCA vaze isso)
JWT_SECRET=e67fd726-bfa9-4684-8f37-4b38e7127106
# JWT_EXPIRE: Duração do Token padrão em segundos (Ex: 3600 = 1 hora)
JWT_EXPIRE=3600
# JWT_REFRESH_EXPIRE: Duração de vida estendida do Refresh Token (em seg)
JWT_REFRESH_EXPIRE=604800